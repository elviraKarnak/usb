# =========================
# wp-content handling
# =========================
/wp-content/*

# ✅ Allow themes
!wp-content/themes/
!wp-content/themes/**

# ✅ Allow plugins (remove if you DON'T want plugins in git)
!wp-content/plugins/
!wp-content/plugins/**

# =========================
# Ignore specific folders (as per your screenshot)
# =========================
wp-content/uploads/
wp-content/backups-dup-pro/
wp-content/cache/
wp-content/upgrade/
wp-content/plugins/
wp-content/upgrade-temp-backup/
wp-content/wflogs/
wp-content/webtoffee_export/
wp-content/webtoffee_import/
wp-content/webtoffee_iew_log/

# Optional ignore
wp-content/languages/
wp-content/maintenance/

# =========================
# Logs & system
# =========================
*.log
error_log

